<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Single console appender — no custom encoder classes (native-image safe) -->
    <!-- JSON structured format for prod is applied via Spring Boot's logging.structured.format.console property -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{requestId}] [%X{username}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fallback root if no profile matches (e.g. springProfile processing fails in native) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Local/dev: readable logs -->
    <springProfile name="local | dev | default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="it.iacovelli.nexabudgetbe" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>
    </springProfile>

    <!-- Prod/Kubernetes: JSON structured format enabled via application-prod.properties -->
    <springProfile name="prod | kubernetes">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="it.iacovelli.nexabudgetbe" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.springframework.boot" level="INFO"/>
        <logger name="org.hibernate" level="WARN"/>
    </springProfile>
</configuration>
